{
	"name": "@purpleduck/bun-plugin-solid2",
	"type": "module",
	"version": "0.0.0",
	"workspaces": [
		"test",
		"test/fixtures/*"
	],
	"description": "solid-js 2.0 plugin for Bun with HMR",
